<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="page-shell">
        <div class="glass-panel">
            <!-- Results Header -->
            <div class="results-header">

                <div class="signature-horsey" aria-hidden="true">♞</div> <!-- Brand Signature -->
                <h1>Quote Results</h1>
                <p class="results-subtitle">
                    <% if (rows.length === 0) { %>
                        No quotes found
                    <% } else if (rows.length === 1) { %>
                        1 quote found
                    <% } else { %>
                        <%= rows.length %> quotes found
                    <% } %>
                </p>
            </div>
            <div id="authorInfo" style="display:none;">
                <h1 id="authorNames"></h1>
                <img id="authorImg" alt="Author portrait" style="display:none;">
            </div>

            <!-- Quote Cards or Empty State -->

            <% if (rows.length === 0) { %>
                <div class="empty-state">
                    <p>No quotes match your search. Try a different keyword or author.</p>
                </div>
            <% } else { %>
                <% for (let quote of rows) { %>
                    <div class="quote-card">
                        <p class="quote-text"><%= quote.quote %></p>
                        <p class="quote-author">
                            <a href="#" class="authorNames" authorID="<%= quote.authorID %>">
                                <%= quote.firstName %> <%= quote.lastName %>
                            </a>
                        </p>
                        <% if (quote.likes !== undefined) { %>
                            <p class="quote-likes">Likes: <%= quote.likes %></p>
                        <% } %>
                    </div>
                <% } %>
            <% } %>

            <!-- Author Dropdown Form (Always Available) -->
            <div class="form-divider">
                <div class="form-divider-label">Search Again</div>
            </div>

            <div class="form-row">
                <label for="authorID">Search by Author</label>
                <form action="/searchByAuthor" method="GET">
                    <select name="authorID" id="authorID" required>
                        <option value="">-- Select an author --</option>
                        <% for (let author of authors) { %>
                            <option value="<%= author.authorID %>">
                                <%= author.firstName %> <%= author.lastName %>
                            </option>
                        <% } %>
                    </select>
                    <button type="submit">Show Quotes</button>
                </form>
            </div>

            <!-- Link Back Home -->
            <div style="text-align: center; margin-top: 2rem;">
                <a href="/" style="color: rgba(100, 200, 255, 0.8); text-decoration: none; font-size: 0.95rem;">
                    ← Back to Home
                </a>
            </div>
        </div>
    </div>

    <div class="modal fade" id="authorModal" tabindex="-1" aria-labelledby="authorModalTitle" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="authorModalTitle">Author Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="author-modal-content">
                        <img id="authorModalImage" src="/images/tron.png" alt="Author portrait" class="author-modal-img">
                        <p id="authorModalDates" class="author-modal-dates"></p>
                        <p id="authorModalBio" class="author-modal-bio"></p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
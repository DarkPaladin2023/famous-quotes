<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="page-shell">
        <div class="glass-panel">
            <!-- Results Header -->
            <div class="results-header">

                <div class="signature-horsey" aria-hidden="true">♞</div> <!-- Brand Signature -->
                <h1>Quote Results</h1>
                <p class="results-subtitle">
                    <% if (rows.length === 0) { %>
                        No quotes found
                    <% } else if (rows.length === 1) { %>
                        1 quote found
                    <% } else { %>
                        <%= rows.length %> quotes found
                    <% } %>
                </p>
            </div>
<div id = "authorInfo">

<h1 id="authorNames"></h1>
<img id = "authorImg">  

</div>

<script>
    // adding an event listener to display author info when an author name is clicked 
    document.addEventListener("DOMContentLoaded", function(){
        let authorLinks = document.querySelectorAll(".authorNames");
        for (let i of authorLinks) {
            i.addEventListener("click", function(event){
                event.preventDefault();
                displayAuthorInfo.call(this);
            });
        }
    });
    
    async function displayAuthorInfo(){
        let authorID = this.getAttribute("authorID");
        let url = "/api/author/" + authorID;
        try {
            let response = await fetch(url);
            let data = await response.json();
            document.getElementById("authorNames").textContent = data.firstName + " " + data.lastName;
            if (data.biography) {
                document.getElementById("authorImg").alt = data.firstName + " " + data.lastName;
            }
        } catch (err) {
            console.error("Error fetching author info:", err);
        }
    }

</script>

            <!-- Quote Cards or Empty State -->
            <% if (rows.length === 0) { %>
                <div class="empty-state">
                    <p>No quotes match your search. Try a different keyword or author.</p>
                </div>
            <% } else { %>
                <% for (let quote of rows) { %>
                    <div class="quote-card">
                        <p class="quote-text"><%= quote.quote %></p>
                        <p class="quote-author">
                            <a href="/searchByAuthor?authorID=<%= quote.authorID %>" class="authorNames" authorID="<%= quote.authorID %>">
                                <%= quote.firstName %> <%= quote.lastName %>
                            </a>
                        </p>
                        <% if (quote.likes !== undefined) { %>
                            <p class="quote-likes">Likes: <%= quote.likes %></p>
                        <% } %>
                    </div>
                <% } %>
            <% } %>

            <!-- Author Dropdown Form (Always Available) -->
            <div class="form-divider">
                <div class="form-divider-label">Search Again</div>
            </div>

            <div class="form-row">
                <label for="authorID">Search by Author</label>
                <form action="/searchByAuthor" method="GET">
                    <select name="authorID" id="authorID" required>
                        <option value="">-- Select an author --</option>
                        <% for (let author of authors) { %>
                            <option value="<%= author.authorID %>">
                                <%= author.firstName %> <%= author.lastName %>
                            </option>
                        <% } %>
                    </select>
                    <button type="submit">Show Quotes</button>
                </form>
            </div>

            <!-- Link Back Home -->
            <div style="text-align: center; margin-top: 2rem;">
                <a href="/" style="color: rgba(100, 200, 255, 0.8); text-decoration: none; font-size: 0.95rem;">
                    ← Back to Home
                </a>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>
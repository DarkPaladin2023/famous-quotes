<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <div class="page-shell">
        <div class="glass-panel">
            
            <h1>Quote Finder</h1>
            <div class="admin-horse">
                <a href="/login" title="Admin Login" aria-label="Admin Login">♞</a>
            </div>
            <div class="signature-horsey" aria-hidden="true">♞</div> <!-- Brand Signature -->
            <p class="subtitle">Discover wisdom from great minds</p>

            <!-- Search by Keyword Form -->
            <div class="form-row">
                <label for="keyword">Search by Keyword</label>
                <form id="searchByKeywordForm" action="/searchByKeyword" method="GET"> <!-- Added an ID for easier targeting of the form, do this for all forms -->
                    <input 
                        type="text" 
                        id="keyword" 
                        name="keyword" 
                        placeholder="e.g., love, wisdom, success..." 
                        required>
                    <button type="submit">Search Quotes</button>
                    <p id="keywordError" class="form-error"></p>
                </form>
            </div>

            <!-- Divider -->
            <div class="form-divider">
                <div class="form-divider-label">Or</div>
            </div>


            <!-- Search by Author Form -->
            <div class="form-row">
                <label for="authorId">Search by Author</label>
                <form action="/searchByAuthor" method="GET">
                    <select name="authorID" id="authorId" required>
                        <option value="">-- Select an author --</option>
                        <% for (let author of authors) { %>
                            <option value="<%= author.authorId %>">
                                <%= author.firstName %> <%= author.lastName %>
                            </option>
                        <% } %>
                    </select>
                    <button type="submit">Show Quotes</button>
                </form>
            </div>

            <!-- Divider -->
            <div class="form-divider">
                <div class="form-divider-label">Or</div>
            </div>

            <!-- Search by Category Form -->
            <div class="form-row">
                <label for="category">Search by Category</label>
                <form action="/searchByCategory" method="GET">
                    <select name="category" id="category" required>
                        <option value="">-- Select a category --</option>
                        <% for (let cat of categories) { %>
                            <option value="<%= cat.category %>"><%= cat.category %></option>
                        <% } %>
                    </select>
                    <button type="submit">Show Quotes</button>
                </form>
            </div>

            <!-- Divider -->
            <div class="form-divider">
                <div class="form-divider-label">Or</div>
            </div>

            <!-- Search by Likes Form -->
            <div class="form-row">
                <label for="likes">Search by Likes Range</label>
                <form action="/searchByLikes" method="GET">
                    <div style="display: flex; gap: 1rem; margin-bottom: 1rem;">
                        <input 
                            type="number" 
                            name="minLikes" 
                            placeholder="Min likes" 
                            min="0" 
                            style="flex: 1;">
                        <input 
                            type="number" 
                            name="maxLikes" 
                            placeholder="Max likes" 
                            min="0" 
                            style="flex: 1;">
                    </div>
                    <button type="submit">Show Quotes</button>
                </form>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>
</body>
</html>